{
  "appId": "com.brikops.app",
  "appName": "BrikOps",
  "webDir": "build",
  "ios": {
    "allowsBackForwardNavigationGestures": true,
    "preferredContentMode": "mobile"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": false,
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "CapacitorUpdater": {
      "autoUpdate": true,
      "channel": "production"
    }
  }
}
