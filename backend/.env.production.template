# ============================================================
# BrikOps Backend — Production Environment Variables
# ============================================================
# Copy to .env or set in ECS Task Definition / Secrets Manager.
# Lines marked [REQUIRED] must be set. Others have defaults.
# Do NOT commit actual secrets to version control.
# AWS credentials are NOT needed — use IAM Task Role on ECS.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
APP_ID=brikops-prod                       # [REQUIRED] unique instance id
APP_MODE=prod                             # [REQUIRED] "dev" or "prod"
PUBLIC_APP_URL=https://app.brikops.com    # [REQUIRED] public frontend URL
RELEASE_SHA=                              # set by CI (git rev-parse --short HEAD)

# ── Database ─────────────────────────────────────────────────
MONGO_URL=mongodb+srv://...               # [REQUIRED] Atlas connection string
DB_NAME=contractor_ops                    # [REQUIRED] database name

# ── Authentication / JWT ─────────────────────────────────────
JWT_SECRET=                               # [REQUIRED] min 32 chars, HS256 signing key
JWT_SECRET_VERSION=1                      # [REQUIRED] increment on rotation
JWT_EXPIRATION_HOURS=720                  # token TTL (default 30 days)

# ── File Storage (S3) ───────────────────────────────────────
# No AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY needed on ECS —
# boto3 uses the IAM Task Role automatically.
FILES_STORAGE_BACKEND=s3                  # [REQUIRED] "local" or "s3"
AWS_S3_BUCKET=brikops-prod-files          # [REQUIRED in s3 mode]
AWS_REGION=eu-central-1                   # bucket region
AWS_S3_PRESIGNED_URL_EXPIRES=900          # presigned URL TTL seconds

# ── WhatsApp (Meta Cloud API) ───────────────────────────────
WHATSAPP_ENABLED=true                     # master toggle
WA_ACCESS_TOKEN=                          # [REQUIRED if WA enabled] Meta API token
WA_PHONE_NUMBER_ID=                       # [REQUIRED if WA enabled]
WABA_ID=                                  # WhatsApp Business Account ID
WA_TEMPLATE_NEW_DEFECT=brikops_defect_new
WA_TEMPLATE_LANG=he
WA_TEMPLATE_INVITE=brikops_invite
WA_TEMPLATE_INVITE_LANG=he
WA_INVITE_ENABLED=true
WA_WEBHOOK_VERIFY_TOKEN=                  # [REQUIRED if WA enabled] webhook verify token
META_APP_SECRET=                          # [REQUIRED if WA enabled] for signature validation

# ── SMS (Twilio) ─────────────────────────────────────────────
SMS_ENABLED=true                          # master toggle
SMS_MODE=live                             # "live" or "stub"
TWILIO_ACCOUNT_SID=                       # [REQUIRED if SMS enabled]
TWILIO_AUTH_TOKEN=                        # [REQUIRED if SMS enabled]
TWILIO_FROM_NUMBER=                       # [REQUIRED if SMS enabled]
TWILIO_MESSAGING_SERVICE_SID=             # optional, overrides FROM_NUMBER
OTP_SMS_FALLBACK_SECONDS=25              # delay before WA→SMS fallback

# ── OTP Settings ─────────────────────────────────────────────
OTP_PROVIDER=meta                         # "meta", "twilio", or "mock"
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
ANDROID_APP_HASH=                         # 11-char hash from release keystore; enables Android SMS Retriever autofill (no READ_SMS perm)
OTP_RATE_LIMIT_SECONDS=90

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                                # [REQUIRED for email features]
SMTP_PASS=                                # [REQUIRED for email features]
SMTP_FROM=noreply@brikops.com
SMTP_FROM_NAME=BrikOps
SMTP_REPLY_TO=support@brikops.com
STEPUP_EMAIL=                             # step-up auth fallback email

# ── Super Admin ──────────────────────────────────────────────
SUPER_ADMIN_PHONES=+972...                # [REQUIRED] comma-separated E.164
OWNER_PHONE=+972...                       # fallback owner phone

# ── Feature Flags ────────────────────────────────────────────
BILLING_V1_ENABLED=true
ENABLE_AUTO_TRIAL=true
ENABLE_ONBOARDING_V2=true
ENABLE_QUICK_LOGIN=false                  # MUST be false in prod
ENABLE_DEBUG_ENDPOINTS=false              # MUST be false in prod
ENABLE_API_DOCS=false
ENABLE_COMPLETE_ACCOUNT_GATE=enforce      # "off", "soft", "enforce"
RUN_SEED=false

# ── Networking ───────────────────────────────────────────────
CORS_ORIGINS=https://app.brikops.com      # [REQUIRED] comma-separated allowed origins
ALLOWED_HOSTS=api.brikops.com             # optional host header check
