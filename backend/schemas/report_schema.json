{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BedekPro Inspection Report",
  "description": "Complete schema for property inspection report data",
  "type": "object",
  "required": [
    "report_meta",
    "property_details",
    "categories_summary",
    "findings",
    "financial_summary"
  ],
  "properties": {
    "report_meta": {
      "type": "object",
      "required": ["report_date", "client_name", "inspector_name"],
      "properties": {
        "report_date": {
          "type": "string",
          "format": "date",
          "description": "Report generation date (YYYY-MM-DD)"
        },
        "inspection_date": {
          "type": "string",
          "format": "date",
          "description": "Property inspection date (YYYY-MM-DD)"
        },
        "client_name": {
          "type": "string",
          "description": "Client/tenant name"
        },
        "inspector_name": {
          "type": "string",
          "description": "Inspector's full name"
        },
        "company_name": {
          "type": "string",
          "default": "צע שמי יזמות בע״מ"
        }
      }
    },
    "contact_info": {
      "type": "object",
      "properties": {
        "email": {"type": "string", "format": "email"},
        "phone": {"type": "string"},
        "address": {"type": "string"},
        "company_name": {"type": "string"}
      }
    },
    "property_details": {
      "type": "object",
      "required": ["address"],
      "properties": {
        "address": {"type": "string"},
        "apt_number": {"type": "string"},
        "property_type": {
          "type": "string",
          "default": "דירת מגורים"
        },
        "rooms_count": {"type": "integer"},
        "occupied": {"type": "boolean", "default": false},
        "electricity": {"type": "boolean", "default": true},
        "water": {"type": "boolean", "default": true}
      }
    },
    "categories_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category_name", "count"],
        "properties": {
          "category_name": {
            "type": "string",
            "description": "Category name in Hebrew"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "location",
          "recommendation",
          "unit_price",
          "total_price"
        ],
        "properties": {
          "id": {"type": "string"},
          "category": {"type": "string"},
          "location": {"type": "string"},
          "recommendation": {"type": "string"},
          "standard_ref": {
            "type": "string",
            "description": "Standard/regulation reference"
          },
          "unit": {
            "type": "string",
            "default": "קומפ'",
            "description": "Unit of measurement"
          },
          "qty": {
            "type": "number",
            "minimum": 0,
            "default": 1
          },
          "unit_price": {
            "type": "number",
            "minimum": 0
          },
          "total_price": {
            "type": "number",
            "minimum": 0
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {"type": "string", "format": "uri"},
                "caption": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "financial_summary": {
      "type": "object",
      "required": ["subtotal", "grand_total"],
      "properties": {
        "subtotal": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of all findings"
        },
        "contingency_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 0
        },
        "contingency_amount": {
          "type": "number",
          "minimum": 0
        },
        "supervision_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 10,
          "description": "Engineering supervision percentage"
        },
        "supervision_amount": {
          "type": "number",
          "minimum": 0
        },
        "before_vat": {
          "type": "number",
          "minimum": 0
        },
        "vat_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 18,
          "description": "VAT percentage"
        },
        "vat_amount": {
          "type": "number",
          "minimum": 0
        },
        "grand_total": {
          "type": "number",
          "minimum": 0,
          "description": "Final total including all taxes and fees"
        }
      }
    },
    "closing_notes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Additional notes and disclaimers"
    }
  }
}