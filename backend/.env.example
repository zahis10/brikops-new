# BrikOps Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit real secrets to version control.

# === REQUIRED: App Identity ===
APP_ID=contractor-ops-001
APP_MODE=dev

# === REQUIRED: JWT Auth ===
# Must be at least 32 characters. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_at_least_32_chars
JWT_SECRET_VERSION=v1

# === REQUIRED: MongoDB ===
# In dev: local MongoDB. In prod: set via Deployments → Secrets as full mongodb+srv:// URI
MONGO_URL=mongodb://localhost:27017
DB_NAME=contractor_ops

# === OPTIONAL: CORS ===
CORS_ORIGINS=*

# === WhatsApp Notifications ===
# Keep 'false' in non-production environments.
WHATSAPP_ENABLED=false
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_TEMPLATE_NEW_DEFECT=
WA_TEMPLATE_INVITE=
META_APP_SECRET=

# === SMS (Twilio) ===
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# === OTP ===
OTP_PROVIDER=mock

# === Super Admin ===
SUPER_ADMIN_PHONES=+972500000000

# === Step-up Auth ===
STEPUP_CHANNEL=email
STEPUP_EMAIL=

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
